# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# EXA_API_KEY: Required for Exa live web search.
# Keep this server-side and do not expose it to the browser.
EXA_API_KEY="MY_EXA_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
